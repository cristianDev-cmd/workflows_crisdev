    {
      "parameters": {
        "jsCode": "\nconst base64Content = $input.first().json.content;\nconst sha = $input.first().json.sha;\n\n// Base64 decode\nconst buff = Buffer.from(base64Content, 'base64');\nconst jsonStr = buff.toString('utf8');\nconst wfObj = JSON.parse(jsonStr);\n\n// Keep sha in the item for later use\nreturn {\n  ...wfObj,\n  _github_sha: sha\n};\n"
      },
      "id": "82398161-4986-4401-a156-fd72ecbd57c4",
      "name": "Parse Workflow",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        -16
      ]
    },
    {
      "parameters": {
        "jsCode": "const wfObj = JSON.parse(JSON.stringify($node['Parse Workflow'].json));\nconst sha = wfObj._github_sha;\ndelete wfObj._github_sha;\n\nconst nuevo_id = $node['Extraer ID'].json.nuevo_id;\n\n// Creamos un nuevo objeto para forzar el orden exacto de las propiedades\nconst orderedWf = {};\n\n// 1. Ponemos 'name' primero (si existe)\nif (wfObj.name !== undefined) {\n  orderedWf.name = wfObj.name;\n}\n\n// 2. Ponemos 'id' justo debajo de 'name'\norderedWf.id = nuevo_id;\n\n// 3. Copiamos el resto de las propiedades debajo\nfor (const key in wfObj) {\n  if (key !== 'name' && key !== 'id') {\n    orderedWf[key] = wfObj[key];\n  }\n}\n\n// Convertimos a texto (ahora stringify respetará el orden)\nconst contentStr = JSON.stringify(orderedWf, null, 2);\nconst contentBase64 = Buffer.from(contentStr).toString('base64');\n\nreturn {\n  githubPayload: {\n    message: 'fix: asigna ID real ' + nuevo_id,\n    sha: sha,\n    content: contentBase64\n  }\n};\n"
      },
      "id": "09bd7eed-00f1-4f2b-b8f0-c29d5496cff3",
      "name": "Prepare Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1504,
        -16
      ]
    }
