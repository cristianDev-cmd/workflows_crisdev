      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst archivos = body?.head_commit?.added || [];\n\n// Solo procesar si se crearon archivos JSON nuevos\nconst nuevos = archivos.filter(f => f.endsWith('.json'));\n\nif (nuevos.length === 0) {\n  return { procesar: false, log: 'No hay archivos JSON nuevos en este push' };\n}\n\nreturn {\n  procesar: true,\n  archivo: nuevos[0],\n  log: `Nuevo workflow detectado: ${nuevos[0]}`,\n  owner: body?.repository?.owner?.name,\n  repo: body?.repository?.name\n};"
      },
