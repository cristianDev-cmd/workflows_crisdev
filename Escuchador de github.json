    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nlet rawContent = input.content;\n// Si viene base64\nif (input.encoding === 'base64' && !rawContent && input.raw) {\n  rawContent = Buffer.from(input.raw, 'base64').toString();\n}\nif (!rawContent) {\n  console.log('Keys:', Object.keys(input));\n  console.log('Preview:', JSON.stringify(input).substring(0,300));\n  throw new Error(`Sin contenido. Keys: ${Object.keys(input).join(', ')}`);\n}\nconst json_workflow = JSON.parse(rawContent);\nreturn { json_workflow, log: `OK: ${json_workflow.name}` };"
      },
